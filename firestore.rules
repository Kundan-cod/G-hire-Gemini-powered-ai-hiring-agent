rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.userId == request.auth.uid;
    }

    function isValidFreelancer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.userId == request.auth.uid &&
             (!('email' in data) || data.email is string);
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "kundanchaurasiya839@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if (isOwner(resource.data.userId) && isValidProject(request.resource.data)) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /freelancers/{freelancerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFreelancer(request.resource.data);
      allow update: if (isOwner(resource.data.userId) && isValidFreelancer(request.resource.data)) || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /responses/{responseId} {
      allow read: if isAuthenticated(); // Simplified for MVP, ideally owner of project
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /negotiations/{negotiationId} {
      allow read: if isOwner(resource.data.userId) || isOwner(resource.data.freelancerUserId) || isAdmin();
      allow create: if isAuthenticated();
    }

    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}
